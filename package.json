{
  "name": "adityakdevin",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "site",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "cv:pdf": "npm run cv:pdf --workspace=site",
    "hygiene": "node scripts/text-hygiene.mjs --all",
    "hygiene:fix": "node scripts/text-hygiene.mjs --fix --all",
    "post": "node apps/social-poster/post.mjs",
    "draft": "node apps/infographic/draft.mjs",
    "render": "node apps/infographic/render.mjs",
    "stage": "node apps/infographic/post.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
